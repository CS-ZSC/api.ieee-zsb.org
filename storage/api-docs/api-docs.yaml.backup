      tags:
        - dashboard
        - committee
      description: >-
        Generated from cURL: curl --location '{{base_url}}/dashboard/committees'
        --request POST --header 'Content-Type: application/json' --data-raw
        '{"name": "Technical Committee", "hashtag": "tech", "description":
        "Responsible for technical activities and workshops...", "image":
