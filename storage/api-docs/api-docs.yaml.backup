openapi: 3.0.0
info:
  title: IEEE
  version: 1.0.0
  description: 'IEEE Backend API Documentation organized into 3 main sections'
servers:
  - url: '{{baseURL}}'
  - url: '{{base_url}}'
  - url: ''
  - url: '{{base_url}}site'
tags:
  - name: Dashboard
    description: 'Backend admin routes - requires authentication and admin permissions'
  - name: Site
    description: 'Public frontend routes - accessible to all users'
  - name: EventsGate
    description: 'Visitor portal routes - for event registration and management'
x-tagGroups:
  - name: Dashboard (Backend Admin)
    tags:
      - Dashboard
  - name: Site (Public Frontend)
    tags:
      - Site
  - name: EventsGate (Visitor Portal)
    tags:
      - EventsGate
paths:
  /api/dashboard/auth/login:
    post:
      summary: login
      responses: {}
      tags:
        - dashboard
        - auth
      security:
        - BearerAuth: []
      requestBody:
        content:
          application/json:
            schema:
              type: object
              properties:
                email:
                  type: string
                  format: email
                password:
                  type: string
                  format: utc-millisec
            example:
              email: abdallahhamada2103@gmail.com
              password: '12345678'
  /api/dashboard/auth/logout:
    post:
      summary: logout
      responses: {}
      tags:
        - dashboard
        - auth
      security:
        - BearerAuth: []
      requestBody:
        content:
          application/json:
            schema:
              type: object
              properties:
                email:
                  type: string
                  format: email
                password:
                  type: string
                  format: utc-millisec
            example:
              email: john@example.com
              password: '12345678'
  /api/dashboard/users:
    get:
      summary: index
      responses: {}
      tags:
        - dashboard
        - users
      security:
        - BearerAuth: []
  /api/dashboard/users/1:
    get:
      summary: show
      responses: {}
      tags:
        - dashboard
        - users
      security:
        - BearerAuth: []
  /api/dashboard/users/18:
    put:
      summary: update
      responses: {}
      tags:
        - dashboard
        - users
      security:
        - BearerAuth: []
      requestBody:
        content:
          application/json:
            schema:
              type: object
              properties:
                postions:
                  type: array
                  items:
                    type: integer
            example:
              postions:
                - 11
                - 12
  /api/dashboard/users/2:
    delete:
      summary: delete
      responses: {}
      tags:
        - dashboard
        - users
      security:
        - BearerAuth: []
      requestBody:
        content:
          application/json:
            schema:
              type: object
              properties:
                name:
                  type: string
                email:
                  type: string
                  format: email
                position:
                  type: string
                groupable_id:
                  type: integer
                groupable_type:
                  type: string
                track_id:
                  type: integer
                avatar_src:
                  type: string
                  format: uri
                linkedin:
                  type: string
                  format: uri
            example:
              name: John Doe
              email: john@example.com
              position: ' vice track leader'
              groupable_id: 1
              groupable_type: chapter
              track_id: 1
              avatar_src: https://example.com/avatar.jpg
              linkedin: https://www.linkedin.com
  /dashboard/chapters/:
    get:
      summary: chapter.index
      responses: {}
      tags:
        - dashboard
        - chapter
  /dashboard/chapters/2:
    get:
      summary: chapter.show
      responses: {}
      tags:
        - dashboard
        - chapter
  /dashboard/chapters:
    post:
      summary: chapter.create
