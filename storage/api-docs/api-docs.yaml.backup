      requestBody:
        content:
          application/json:
            schema:
              type: object
              properties:
                name:
                  type: string
                short_name:
                  type: string
                logo:
                  type: string
                color_scheme_1:
                  type: string
                color_scheme_2:
                  type: string
            example:
              name: cs
              short_name: cs
              logo: s
              color_scheme_1: s
              color_scheme_2: s
  /dashboard/chapters/8:
    delete:
      summary: chapter.delete
      responses: {}
      tags:
