                  type: string
                short_name:
                  type: string
                logo:
                  type: string
                color_scheme_1:
                  type: string
                color_scheme_2:
                  type: string
            example:
              name: s
              short_name: s
              logo: s
              color_scheme_1: s
              color_scheme_2: s
  /dashboard/chapters/1:
    put:
      summary: chapter.edit
      responses: {}
