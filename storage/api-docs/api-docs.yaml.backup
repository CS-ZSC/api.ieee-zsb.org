                      descriptions:
                        type: array
                        items:
                          type: string
                      photo:
                        type: string
                      photo_description:
                        type: string
            example:
              title: IEEE Workshop Success
              description: Main description of the news article
              date_created: '2024-02-19'
              author: John Doe
              home_item: true
              tags:
                - workshop
                - ieee
                - success
              main_photo: /Images/news/workshop.jpg
              sections:
                - heading: Workshop Overview
                  descriptions:
                    - First paragraph description
                    - Second paragraph description
                  photo: /Images/news/section1.jpg
                  photo_description: Workshop participants
                - heading: Key Takeaways
                  descriptions:
                    - Important points from the workshop
                  photo: /Images/news/section2.jpg
                  photo_description: Presentation slides
